# Copy to .env and adjust. scripts/run.sh and compose read these.
# (.env is git-ignored by convention; do not commit real values.)

# Logging verbosity for the collector (error|warn|info|debug|trace).
RUST_LOG=info

# STRONGLY RECOMMENDED: your sensor's Bluetooth address, found via:
#   sudo podman run --rm --security-opt label=disable \
#     -v /run/dbus/system_bus_socket:/run/dbus/system_bus_socket \
#     localhost/myinkbird-collector:latest discover
# Leave empty to match by advertised name instead.
INKBIRD_ADDRESS=

# When no address is set, match devices whose name contains this substring.
INKBIRD_NAME_MATCH=ith-13-b

# Minimum seconds between recorded readings for an unchanged sensor.
INKBIRD_MIN_INTERVAL_SECS=60

# Committer identity and interval (local commits only; never pushed).
GIT_AUTHOR_NAME=myinkbird
GIT_AUTHOR_EMAIL=myinkbird@localhost
COMMIT_INTERVAL_SECS=300
